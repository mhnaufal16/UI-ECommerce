# ============================================================
# TEMPLATE .env UNTUK PRODUCTION / HOSTING
# Rename file ini menjadi .env di server hosting Anda
# Isi semua nilai yang bertanda <GANTI_INI>
# ============================================================

APP_NAME="AP Kreasi"
APP_ENV=production
APP_KEY=<GENERATE_DENGAN: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://<DOMAIN_ANDA>.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ─────────────────────────────────────────────────
# Karena ini UI-only (tidak ada backend), SQLite sudah cukup.
# Jika hosting tidak support SQLite, ganti ke MySQL di bawah.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=<NAMA_DATABASE>
# DB_USERNAME=<USERNAME_DB>
# DB_PASSWORD=<PASSWORD_DB>

# ── Session & Cache ──────────────────────────────────────────
# Gunakan "file" agar tidak perlu tabel database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ── Mail (opsional, tidak dipakai di UI-only) ────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="info@apkreasi.com"
MAIL_FROM_NAME="AP Kreasi"
